{
  "name": "narrative-engine-api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "predev": "npm run config:generate",
    "build": "tsc",
    "start": "node dist/index.js",
    "worker": "node dist/jobs/worker.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src tests",
    "typecheck": "tsc --noEmit",
    "config:generate": "tsx scripts/generate-config-seed.ts",
    "config:sync": "tsx scripts/sync-config.ts",
    "config:all": "npm run config:generate && npm run config:sync",
    "seed:patterns": "NODE_PATH=./node_modules tsx ../supabase/seed/load-patterns.ts",
    "smoke": "bash scripts/smoke-test.sh"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.1",
    "@supabase/supabase-js": "^2.49.1",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "bullmq": "^5.41.0",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "ioredis": "^5.5.0",
    "openai": "^4.85.1",
    "pino": "^9.6.0",
    "satori": "^0.12.0",
    "sharp": "^0.33.5",
    "ws": "^8.21.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.13.4",
    "@types/ws": "^8.18.1",
    "eslint": "^9.20.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
