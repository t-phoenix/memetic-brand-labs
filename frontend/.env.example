# Narrative Engine API (required)
VITE_API_URL=http://localhost:3001

# Supabase (required when email auth / wallet rerun is enabled)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=

# Optional — x402 wallet rerun on Base mainnet
VITE_WALLET_CONNECT_PROJECT_ID=
VITE_BASE_CHAIN_ID=8453

# Discovery on marketing site (navbar link + landing CTA).
# Omit locally — Vite dev mode shows them automatically.
# Production (Vercel): leave unset or set to false
# VITE_NE_DISCOVERY=false

# Optional — pre-fill admin key in local dev only (sessionStorage used at runtime)
# VITE_ADMIN_API_KEY=local-test-admin
